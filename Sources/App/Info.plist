<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>pkpass Quick Look</string>
	<key>CFBundleDisplayName</key>
	<string>pkpass Quick Look</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>NSHumanReadableCopyright</key>
	<string>MIT License</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHighResolutionCapable</key>
	<true/>

	<!-- Run as a menu-bar accessory: no Dock icon, stays alive in the
	     background when the window is closed. -->
	<key>LSUIElement</key>
	<true/>

	<!-- Sparkle auto-update. Replace SUPublicEDKey with the key printed by
	     `generate_keys` before distributing; the private key stays in your Keychain. -->
	<key>SUFeedURL</key>
	<string>https://ariomoniri.github.io/ql-pkpass/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>WJW6oDc04x7UBySwM3UPsuzgcyJafp+682VWdVNSt/g=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>

	<!-- Document types the in-app viewer can open. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Apple Wallet Pass</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.apple.pkpass-data</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Google / Samsung Wallet Pass</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.ariomoniri.google-wallet-pass</string>
				<string>com.ariomoniri.samsung-wallet-pass</string>
			</array>
		</dict>
	</array>

	<!-- Exported UTIs for Google / Samsung Wallet passes (no official UTI exists). -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.ariomoniri.google-wallet-pass</string>
			<key>UTTypeDescription</key>
			<string>Google Wallet Pass</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>gwallet</string>
					<string>gpass</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.ariomoniri.samsung-wallet-pass</string>
			<key>UTTypeDescription</key>
			<string>Samsung Wallet Pass</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>swcard</string>
					<string>samsungpass</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
